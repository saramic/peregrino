<button class="<%= css_classes %>"
        data-controller="action-button"
        data-action="click->action-button#activate"
        <%= "data-action-button-reset-after-value=#{@reset_after}" if @reset_after %>
        <%= "disabled" if @loading %>>
  <%= @label %>
  <% if @icons %>
    <span data-action-button-target="icon" aria-hidden="true" class="<%= 'hidden' if @loading %>">
      <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
        <path d="M5 12h14M13 6l6 6-6 6"/>
      </svg>
    </span>
    <span data-action-button-target="spinner" aria-hidden="true" class="<%= 'hidden' unless @loading %>">
      <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" class="animate-spin">
        <path d="M21 12a9 9 0 1 1-6.219-8.56"/>
      </svg>
    </span>
  <% end %>
</button>
