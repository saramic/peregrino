<div class="min-h-screen bg-canvas flex flex-col items-center justify-center gap-4 px-8 py-12"
     data-controller="journey"
     data-action="action-button:activated->journey#locateUser">

  <%# Mountain logomark with wordmark at the waterline %>
  <svg viewBox="0 0 300 180" xmlns="http://www.w3.org/2000/svg"
       class="w-80 max-w-full" role="img" aria-label="Mountain range reflected in a lake, Peregrino wordmark at the horizon">
    <defs>
      <%# Fade reflections from waterline downward %>
      <linearGradient id="reflFade" x1="0" y1="0" x2="0" y2="1">
        <stop offset="0%"   stop-color="white" stop-opacity="1"/>
        <stop offset="75%"  stop-color="white" stop-opacity="0.25"/>
        <stop offset="100%" stop-color="white" stop-opacity="0"/>
      </linearGradient>
      <mask id="reflMask">
        <rect x="0" y="90" width="300" height="90" fill="url(#reflFade)"/>
      </mask>

      <%# Lapping water distortion for reflections — x freq low (broad side-to-side), y freq higher (ripple) %>
      <filter id="waterRipple" x="-5%" width="110%">
        <feTurbulence type="turbulence" baseFrequency="0.012 0.07" numOctaves="2" seed="3" result="noise">
          <animate attributeName="baseFrequency"
                   values="0.012 0.06; 0.012 0.10; 0.012 0.07; 0.012 0.06"
                   dur="7s"
                   repeatCount="indefinite"/>
        </feTurbulence>
        <feDisplacementMap in="SourceGraphic" in2="noise" scale="4"
                           xChannelSelector="R" yChannelSelector="G"/>
      </filter>
    </defs>

    <%# Back range — distant suggestion of ridgeline %>
    <path fill="var(--color-muted)" fill-opacity="0.14"
          d="M 0,90
             C 20,90 45,85 68,78
             C 82,74 94,65 115,63
             C 136,61 148,68 172,66
             C 196,64 215,65 238,67
             C 258,69 278,78 300,82
             L 300,90 Z"/>

    <%# Middle range — second layer of depth %>
    <path fill="var(--color-muted)" fill-opacity="0.32"
          d="M 0,90
             C 15,90 32,88 48,82
             C 58,76 64,58 74,46
             C 82,35 95,40 110,40
             C 125,40 138,54 155,57
             C 168,60 178,43 200,43
             C 218,43 230,58 246,70
             C 262,80 282,87 300,89
             L 300,90 Z"/>

    <%# Front range — main peaks, rounded like eroded sandstone %>
    <path fill="var(--color-muted)" fill-opacity="0.65"
          d="M 0,90
             C 18,90 38,90 55,82
             C 63,76 68,52 76,34
             C 82,20 90,13 105,13
             C 120,13 130,35 145,52
             C 155,62 162,58 170,52
             C 178,46 193,22 208,22
             C 223,22 236,48 250,65
             C 264,78 280,86 300,88
             L 300,90 Z"/>

    <%# Waterline %>
    <line x1="0" y1="90" x2="300" y2="90"
          stroke="var(--color-muted)" stroke-opacity="0.18" stroke-width="0.5"/>

    <%# Reflections — same paths, flipped across y=90, water shimmer applied %>
    <g mask="url(#reflMask)" filter="url(#waterRipple)">
      <path fill="var(--color-muted)" fill-opacity="0.07"
            transform="matrix(1,0,0,-1,0,180)"
            d="M 0,90
               C 20,90 45,85 68,78
               C 82,74 94,65 115,63
               C 136,61 148,68 172,66
               C 196,64 215,65 238,67
               C 258,69 278,78 300,82
               L 300,90 Z"/>
      <path fill="var(--color-muted)" fill-opacity="0.16"
            transform="matrix(1,0,0,-1,0,180)"
            d="M 0,90
               C 15,90 32,88 48,82
               C 58,76 64,58 74,46
               C 82,35 95,40 110,40
               C 125,40 138,54 155,57
               C 168,60 178,43 200,43
               C 218,43 230,58 246,70
               C 262,80 282,87 300,89
               L 300,90 Z"/>
      <path fill="var(--color-muted)" fill-opacity="0.30"
            transform="matrix(1,0,0,-1,0,180)"
            d="M 0,90
               C 18,90 38,90 55,82
               C 63,76 68,52 76,34
               C 82,20 90,13 105,13
               C 120,13 130,35 145,52
               C 155,62 162,58 170,52
               C 178,46 193,22 208,22
               C 223,22 236,48 250,65
               C 264,78 280,86 300,88
               L 300,90 Z"/>

      <%# Reflected wordmark — flipped across y=90, faint %>
      <text x="150" y="90"
            transform="matrix(1,0,0,-1,0,180)"
            text-anchor="middle"
            dominant-baseline="alphabetic"
            font-family="Georgia, 'Times New Roman', serif"
            font-size="40"
            letter-spacing="-0.5"
            fill="var(--color-prose)"
            fill-opacity="0.22">Peregrino</text>
    </g>

    <%# Subtle water shimmer lines %>
    <line x1="25" y1="94"  x2="275" y2="94"  stroke="var(--color-muted)" stroke-opacity="0.06" stroke-width="0.5"/>
    <line x1="45" y1="100" x2="255" y2="100" stroke="var(--color-muted)" stroke-opacity="0.04" stroke-width="0.5"/>

    <%# Wordmark — alphabetic baseline on the waterline %>
    <text x="150" y="88"
          text-anchor="middle"
          dominant-baseline="alphabetic"
          font-family="Georgia, 'Times New Roman', serif"
          font-size="40"
          letter-spacing="-0.5"
          fill="var(--color-prose)"
          data-testid="wordmark">Peregrino</text>
  </svg>

  <%# Tagline %>
  <p class="text-muted text-xs tracking-[0.25em] uppercase -mt-1">Every road is a pilgrimage</p>

  <%# CTA %>
  <div data-journey-target="startControls" data-testid="start-button"
       class="<%= 'hidden ' if start_controls_hidden? %>mt-2">
    <%= render ActionButtonComponent.new(label: "Start") %>
  </div>

  <%# Audio controls — shown once speaking begins %>
  <div data-journey-target="audioControls" data-testid="audio-controls"
       class="<%= 'hidden ' if audio_controls_hidden? %>mt-2">
    <div class="flex items-center gap-3">

      <%# Pause / Resume toggle %>
      <button data-action="journey#togglePause"
              class="inline-flex items-center gap-2 rounded-full border border-muted/50 px-5 py-2.5 text-sm text-muted transition-colors hover:border-brand hover:text-brand">
        <svg data-journey-target="pauseIcon" viewBox="0 0 14 14" fill="currentColor"
             class="<%= 'hidden ' if pause_icon_hidden? %>w-3.5 h-3.5" aria-hidden="true">
          <rect x="2" y="1" width="3.5" height="12" rx="1"/>
          <rect x="8.5" y="1" width="3.5" height="12" rx="1"/>
        </svg>
        <svg data-journey-target="playIcon" viewBox="0 0 14 14" fill="currentColor"
             class="<%= 'hidden ' if play_icon_hidden? %>w-3.5 h-3.5" aria-hidden="true">
          <path d="M3 1.5l9 5-9 5z"/>
        </svg>
        <span data-journey-target="pauseLabel"><%= pause_label %></span>
      </button>

      <%# Restart — reloads back to the home screen %>
      <button data-action="journey#restart"
              class="inline-flex items-center gap-2 rounded-full border border-muted/50 px-5 py-2.5 text-sm text-muted transition-colors hover:border-brand hover:text-brand">
        <svg viewBox="0 0 14 14" fill="none" stroke="currentColor" stroke-width="1.5"
             class="w-3.5 h-3.5" aria-hidden="true">
          <path d="M1 7a6 6 0 1 0 6-6" stroke-linecap="round"/>
          <path d="M1 3v4h4" stroke-linecap="round" stroke-linejoin="round"/>
        </svg>
        Restart
      </button>

    </div>
  </div>

  <%# Journey progress — hidden until Start is tapped %>
  <ol data-journey-target="steps" data-testid="journey-steps"
      class="<%= 'hidden ' if steps_hidden? %>mt-6 w-full max-w-xs text-sm space-y-3">

    <%# Step 1: Location %>
    <li class="flex items-center gap-3" data-testid="step-location">
      <span class="group relative w-5 h-5 shrink-0 text-muted"
            data-journey-target="locationIcon" data-status="<%= location_status %>">
        <svg class="absolute inset-0 w-5 h-5 group-data-[status=active]:hidden group-data-[status=done]:hidden"
             viewBox="0 0 20 20" fill="none" aria-hidden="true">
          <circle cx="10" cy="10" r="7" stroke="currentColor" stroke-opacity="0.4" stroke-width="1.5"/>
        </svg>
        <svg class="absolute inset-0 w-5 h-5 hidden group-data-[status=active]:block animate-spin text-brand"
             viewBox="0 0 20 20" fill="none" aria-hidden="true">
          <circle cx="10" cy="10" r="7" stroke="currentColor" stroke-opacity="0.25" stroke-width="1.5"/>
          <path d="M17 10a7 7 0 0 0-7-7" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>
        </svg>
        <svg class="absolute inset-0 w-5 h-5 hidden group-data-[status=done]:block text-brand"
             viewBox="0 0 20 20" fill="none" aria-hidden="true">
          <circle cx="10" cy="10" r="8" fill="currentColor" fill-opacity="0.15"/>
          <path d="M6.5 10l2.5 2.5 4.5-4.5" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
        </svg>
      </span>
      <span>
        <span class="text-prose">Location</span>
        <span data-journey-target="locationDetail"
              class="<%= 'hidden ' if location_detail_hidden? %>block text-xs font-mono text-muted mt-0.5">
          <%= @location_detail %>
        </span>
      </span>
    </li>

    <%# Step 2: Fetching data %>
    <li class="flex items-center gap-3 <%= 'opacity-40 ' if data_step_dim? %>transition-opacity duration-500"
        data-journey-target="dataStep" data-testid="step-data">
      <span class="group relative w-5 h-5 shrink-0 text-muted"
            data-journey-target="dataIcon" data-status="<%= data_status %>">
        <svg class="absolute inset-0 w-5 h-5 group-data-[status=active]:hidden group-data-[status=done]:hidden"
             viewBox="0 0 20 20" fill="none" aria-hidden="true">
          <circle cx="10" cy="10" r="7" stroke="currentColor" stroke-opacity="0.4" stroke-width="1.5"/>
        </svg>
        <svg class="absolute inset-0 w-5 h-5 hidden group-data-[status=active]:block animate-spin text-brand"
             viewBox="0 0 20 20" fill="none" aria-hidden="true">
          <circle cx="10" cy="10" r="7" stroke="currentColor" stroke-opacity="0.25" stroke-width="1.5"/>
          <path d="M17 10a7 7 0 0 0-7-7" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>
        </svg>
        <svg class="absolute inset-0 w-5 h-5 hidden group-data-[status=done]:block text-brand"
             viewBox="0 0 20 20" fill="none" aria-hidden="true">
          <circle cx="10" cy="10" r="8" fill="currentColor" fill-opacity="0.15"/>
          <path d="M6.5 10l2.5 2.5 4.5-4.5" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
        </svg>
      </span>
      <span>
        <span class="text-prose">Fetching data</span>
        <span data-journey-target="dataDetail"
              class="<%= 'hidden ' if data_detail_hidden? %>block text-xs font-mono text-muted mt-0.5">
          <%= @data_detail %>
        </span>
      </span>
    </li>

    <%# Step 3: Preparing audio %>
    <li class="flex items-center gap-3 <%= 'opacity-40 ' if audio_step_dim? %>transition-opacity duration-500"
        data-journey-target="audioStep" data-testid="step-audio">
      <span class="group relative w-5 h-5 shrink-0 text-muted"
            data-journey-target="audioIcon" data-status="<%= audio_status %>">
        <svg class="absolute inset-0 w-5 h-5 group-data-[status=active]:hidden group-data-[status=done]:hidden"
             viewBox="0 0 20 20" fill="none" aria-hidden="true">
          <path d="M3 8h4l4-3v10l-4-3H3z" stroke="currentColor" stroke-opacity="0.4" stroke-width="1.3" stroke-linejoin="round"/>
          <path d="M13 8a3.5 3.5 0 0 1 0 4" stroke="currentColor" stroke-opacity="0.4" stroke-width="1.3" stroke-linecap="round"/>
        </svg>
        <svg class="absolute inset-0 w-5 h-5 hidden group-data-[status=active]:block text-brand"
             viewBox="0 0 20 20" fill="none" aria-hidden="true">
          <path d="M3 8h4l4-3v10l-4-3H3z" stroke="currentColor" stroke-width="1.3" stroke-linejoin="round"/>
          <path d="M13 8a3.5 3.5 0 0 1 0 4" stroke="currentColor" stroke-width="1.3" stroke-linecap="round">
            <animate attributeName="stroke-opacity" values="1;0.2;1" dur="1.2s" repeatCount="indefinite"/>
          </path>
          <path d="M15.5 5.5a6 6 0 0 1 0 9" stroke="currentColor" stroke-width="1.3" stroke-linecap="round">
            <animate attributeName="stroke-opacity" values="1;0.2;1" dur="1.2s" begin="0.4s" repeatCount="indefinite"/>
          </path>
        </svg>
        <svg class="absolute inset-0 w-5 h-5 hidden group-data-[status=done]:block text-brand"
             viewBox="0 0 20 20" fill="none" aria-hidden="true">
          <circle cx="10" cy="10" r="8" fill="currentColor" fill-opacity="0.15"/>
          <path d="M6.5 10l2.5 2.5 4.5-4.5" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
        </svg>
      </span>
      <span class="text-prose">Preparing audio</span>
    </li>

  </ol>
</div>
