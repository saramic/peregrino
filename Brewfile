# mange dependencies with brew https://brew.sh/

#
# Runtimes
#
brew "mise"                     # Extendable version manager with support for
                                # Ruby, Node.js, Erlang & more
                                # https://asdf-vm.com/

#
# Containerisation
#
brew "docker-buildx"            # Docker CLI plugin for extended build
                                # capabilities with BuildKit
                                # https://docs.docker.com/buildx/working-with-buildx/
brew "colima"                   # Container runtimes on MacOS (and Linux) with
                                # minimal setup https://colima.run
